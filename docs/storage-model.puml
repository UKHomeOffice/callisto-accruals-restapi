@startuml

entity time_entry {
  * id : number <<PK>>
  --
  * version
  * ownerid
  * actual_start_time
  * actual_end_time
}

entity flex_change {
  * id : number <<PK>>
  --
  * time_entry_id: number <<FK>>
}

entity accrual {
  * id : number <<PK>>
  --
  * type_id : number <<FK>>
  --
  * balance : number
  * date : date
}

entity contribution {
  * id : number <<PK>>
  --
  * time_entry_id : number <<FK>>
  * accrual_id : number <<FK>>
  --
  * value : number
}

entity accrual_type {
  * id : number <<PK>>
  --
  * name : string
  * measurement_unit : enumeration
}

accrual ||.. accrual_type
contribution ||.. accrual
contribution ||.. time_entry
flex_change ||.. time_entry


entity person {
  * id : number <<PK>>
  --
  * employment_type : string
  * location_code : string
  
}

person ||.. time_entry

@enduml